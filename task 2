if (abs($средний_балл - $ожидаемый_средний) < 0.01) {
    echo "<span style='color: green;'>$средний_балл ✓</span></p>";
} else {
    echo "<span style='color: red;'>$средний_балл (ожидалось: ~$ожидаемый_средний) ✗</span></p>";
}


$лучший = getBestStudent($студенты);
